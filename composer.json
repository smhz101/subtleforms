{
  "name": "muzammil/subtleforms",
  "description": "most subtle and elite forms power house",
  "type": "project",
  "autoload": {
    "psr-4": {
      "SubtleForms\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SubtleForms\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Muzammil Hussain",
      "email": "smhz101@gmail.com"
    }
  ],
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "yoast/phpunit-polyfills": "^4.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit --testsuite unit",
    "test:unit": "vendor/bin/phpunit --testsuite unit",
    "test:integration": "vendor/bin/phpunit --testsuite integration --bootstrap tests/bootstrap.php",
    "test:all": "vendor/bin/phpunit"
  }
}
