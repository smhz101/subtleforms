{
  "name": "subtleforms-admin",
  "version": "1.6.6",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "wp-scripts start ./resources/admin/index.jsx --output-path=./build/admin --output-filename=admin.js",
    "build": "wp-scripts build ./resources/admin/index.jsx --output-path=./build/admin --output-filename=admin.js",
    "start:frontend": "wp-scripts start ./resources/frontend/index.jsx --output-path=./build/frontend --output-filename=frontend.js",
    "build:frontend": "wp-scripts build ./resources/frontend/index.jsx --output-path=./build/frontend --output-filename=frontend.js",
    "start:block": "wp-scripts start ./resources/blocks/form/index.js --output-path=./build/blocks/form",
    "build:block": "wp-scripts build ./resources/blocks/form/index.js --output-path=./build/blocks/form && cp resources/blocks/form/block.json resources/blocks/form/editor.css build/blocks/form/",
    "build:subtleforms-block": "wp-scripts build ./resources/blocks/subtleforms-form/index.js --output-path=./build/blocks/subtleforms-form && cp resources/blocks/subtleforms-form/block.json resources/blocks/subtleforms-form/editor.css build/blocks/subtleforms-form/",
    "build:all": "npm run build && npm run build:frontend && npm run build:block && npm run build:subtleforms-block",
    "test": "wp-scripts test-unit-js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:regression": "playwright test tests/e2e/regression-*.spec.js --reporter=html,list --timeout=90000",
    "test:regression:headed": "playwright test tests/e2e/regression-*.spec.js --reporter=list --timeout=90000 --headed",
    "dist": "gulp dist",
    "dist:build": "gulp build",
    "dist:zip": "gulp zip",
    "dist:clean": "gulp clean"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/react-hooks": "^7.0.2",
    "@wordpress/e2e-test-utils-playwright": "^1.37.0",
    "@wordpress/scripts": "^31.1.0",
    "gulp-zip": "^5.1.0",
    "rimraf": "^6.1.2"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.0.8",
    "@dnd-kit/sortable": "^7.0.2",
    "@dnd-kit/utilities": "^3.2.1",
    "@wordpress/components": "^30.9.0",
    "@wordpress/element": "^6.36.0",
    "@wordpress/i18n": "^6.9.0",
    "clsx": "^2.1.1",
    "joi": "^18.0.2",
    "lucide-react": "^0.562.0",
    "nanoid": "^3.3.11"
  }
}
