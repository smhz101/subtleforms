{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "subtleforms/subtleforms-form",
  "version": "1.0.0",
  "title": "SubtleForms Form",
  "category": "widgets",
  "description": "Embed a SubtleForms form",
  "icon": "feedback",
  "keywords": ["form", "contact", "subtleforms", "embed"],
  "textdomain": "subtleforms",
  "supports": {
    "align": true,
    "html": false,
    "customClassName": true
  },
  "attributes": {
    "formId": {
      "type": "number",
      "default": 0
    },
    "align": {
      "type": "string"
    }
  },
  "example": {
    "attributes": {
      "formId": 0
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css"
}
